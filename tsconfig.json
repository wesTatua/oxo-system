{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@core/*":          ["src/core/*"],
      "@domain/*":        ["src/domain/*"],
      "@data/*":          ["src/data/*"],
      "@presentation/*":  ["src/presentation/*"],
      "@shared/*":        ["src/shared/*"],
      "@assets/*":        ["assets/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts"]
}
