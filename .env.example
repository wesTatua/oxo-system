# OXO_System — variáveis de ambiente
# Copie para .env.local e ajuste o valor antes de rodar `npx expo start`

# URL pública da API Python (FastAPI). Como o app roda no Codespace/Expo Go
# e a API roda no notebook do Comandante, use a URL do túnel Cloudflare ativo
# (gerada por cloudflared / iniciar_oxo.bat), nunca localhost.
EXPO_PUBLIC_API_URL=https://SUBSTITUA-PELA-URL-DO-TUNNEL.trycloudflare.com
